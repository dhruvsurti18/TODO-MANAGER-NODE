<%- include("header/header") %>

<h1 class="mb-4">Dashboard</h1>

<div class="row mb-4">
  <div class="col-md-4">
    <div class="card p-3 text-center">
      <h5>Total Tasks</h5>
      <h2><%= total %></h2>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card p-3 text-center">
      <h5>Pending</h5>
      <h2><%= pending %></h2>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card p-3 text-center">
      <h5>Completed</h5>
      <h2><%= completed %></h2>
    </div>
  </div>
</div>

<a href="/add" class="btn btn-primary mb-3">+ Add Task</a>

<table class="table table-bordered text-center align-middle">
  <tr>
    <th>ID</th>
    <th>Title</th>
    <th>Priority</th>
    <th>Status</th>
    <th>Actions</th>
  </tr>

  <% tasks.forEach(task => { %>
    <tr>
      <td><%= task.id %></td>
      <td><%= task.title %></td>
      <td><%= task.priority %></td>
      <td><%= task.status %></td>
      <td>
        <a href="/status/<%= task.id %>" class="btn btn-warning btn-sm">Change</a>
        <a href="/edit/<%= task.id %>" class="btn btn-info btn-sm">Edit</a>
        <a href="/delete/<%= task.id %>" class="btn btn-danger btn-sm">Delete</a>
      </td>
    </tr>
  <% }) %>

</table>

